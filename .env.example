# SAP S/4HANA Connection
# Run tcode SMICM in SAP GUI to find hostname, system number, and active ports.
# Go to SMICM > Goto > Services to see HTTP/HTTPS ports and their status.
S4HANA_HOSTNAME=your-s4hana-host.example.com
S4HANA_SYSNR=50

# Protocol: true = HTTPS (port 443<sysnr>), false = HTTP (port 80<sysnr>)
# Example: sysnr=50 -> HTTPS port 44350, HTTP port 8050
S4HANA_USE_HTTPS=true

# SAP credentials
S4HANA_USERNAME=YOUR_USER
S4HANA_PASSWORD=YOUR_PASSWORD
S4HANA_CLIENT=001

# OData Service Path (default: /sap/opu/odata/sap/API_BUSINESS_PARTNER)
S4HANA_ODATA_PATH=/sap/opu/odata/sap/API_BUSINESS_PARTNER
